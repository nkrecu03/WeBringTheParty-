@using Microsoft.AspNetCore.Http
@{
    var role = Context.Session.GetString("Role");
    var firstName = Context.Session.GetString("FirstName");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WeBringTheParty_</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WeBringTheParty_.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
</head>

<!-- ── Add to cart toast ── -->
@if (TempData["CartToast"] != null)
{
    <div class="cart-toast" id="cartToast">
        <span class="cart-toast-icon">🛒</span>
        <span>@TempData["CartToast"]</span>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toast = document.getElementById('cartToast');
            setTimeout(() => toast.classList.add('cart-toast-show'), 100);
            setTimeout(() => toast.classList.remove('cart-toast-show'), 3000);
        });
    </script>
}

<body class="@ViewData["BodyClass"]">
    <!--Insert Header-->
    @await Html.PartialAsync("_Header")

    <main role="main" class="page-content">
        @RenderBody()
    </main>    

    @await Html.PartialAsync("_Footer")


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


