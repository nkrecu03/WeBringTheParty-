@using Microsoft.AspNetCore.Http
@{
    var role = Context.Session.GetString("Role");
    var firstName = Context.Session.GetString("FirstName");
}

<header>
    <!-- Top bar -->
    <div class="top-bar d-flex justify-content-between align-items-center p-2">
        <!-- Left Logo -->
        <div class="d-flex align-items-center">
            <img src="~/images/purp_logo.png" alt="Logo" class="img-fluid logo me-2">
            
        </div>

        <!-- Right-side: search + auth buttons -->
        <div class="d-flex align-items-center">
            <!-- Search bar -->
            <input type="text" class="search-bar me-3" placeholder="Search...">

            <!-- Auth buttons -->
            <div class="auth-buttons d-flex align-items-center">
                @if (string.IsNullOrEmpty(firstName))
                {
                    <a class="btn btn-purple me-2" asp-controller="Account" asp-action="Login">Login</a>
                    <a class="btn btn-purple2" asp-controller="User" asp-action="CreateUser">Sign Up</a>
                }
                else
                {
                    <span class="text-black me-3">Hello, @firstName!</span>

                    <a class="btn btn-purple me-2" asp-controller="Order" asp-action="History">
                        <i class="bi bi-clock-history"></i> Orders
                    </a>

                    <a class="btn btn-purple me-2" asp-controller="Cart" asp-action="Index">
                        <i class="bi bi-cart4"></i> Cart
                    </a>
                    <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                        <button type="submit" class="btn btn-purple text-white">Logout</button>
                    </form>

                    @if (role == "Admin")
                    {
                        <a class="btn btn-purple ms-3" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Navbar -->
    <nav class="navbar d-flex justify-content-center" padding:0;">
        <a class="nav-button px-3" href="/">HOME</a>
        <a class="nav-button px-3" href="/Product/ShopAll">SHOP ALL</a>
        <a class="nav-button px-3" href="/About">ABOUT</a>
        <a class="nav-button px-3" href="/Contact">CONTACT</a>
    </nav>
</header>
