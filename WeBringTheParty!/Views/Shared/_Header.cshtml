@using Microsoft.AspNetCore.Http
@{
    var role = Context.Session.GetString("Role");
    var firstName = Context.Session.GetString("FirstName");
}

<header>
    
    <!-- Top bar -->
    <div class="top-bar d-flex justify-content-between align-items-center p-2">
        <!-- Left Corner Site Name -->
        <div class="col-md-6 d-flex">
            <img src="~/images/drawn_logo.png" alt="Sign Up" class="img-fluid logo">
            <h2 class="logo-title">WE BRING</h2>
            <h2 class="logo-title"THE PARTY</h2>
        </div>
    
    <!-- Right-side buttons change depending on login -->
    <div class="auth-buttons d-flex align-items-center">
        @if (string.IsNullOrEmpty(firstName))
        {
            <!-- Not logged in -->
            <a class="btn btn-outline-light me-2" asp-controller="Account" asp-action="Login">Login</a>
            <a class="btn btn-light" asp-controller="User" asp-action="CreateUser">Sign Up</a>
        }
        else
        {
            <!-- Logged in -->
            <span class="text-white me-3">Hello, @firstName!</span>
            <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                <button type="submit" class="btn btn-link text-white" style="display:inline; padding:0;">Logout</button>
            </form>

            @* Show admin dashboard link if user is admin *@
            @if (role == "Admin")
            {
                <a class="btn btn-outline-warning ms-3" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
            }
        }
        </div>
    </div>
   

    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="navbar-container col-12 d-flex justify-content-center">
            <a class="nav-button" asp-controller="Home" asp-action="Index">Home</a>
            <a class="nav-button" asp-controller="Product" asp-action="ShopAll">Shop All</a>
        </div>
    </nav>

</header>
