@using Microsoft.AspNetCore.Http
@{
    var firstName = Context.Session.GetString("FirstName");
}

<footer class="site-footer">
    <div class="footer-main">
        <div class="container">
            <div class="row g-5">

                <!-- Col 1: Brand -->
                <div class="col-lg-4 col-md-6">
                    
                    <p class="footer-tagline">
                        Premium party supplies and rentals delivered straight to your door. We handle the details so you can focus on the celebration.
                    </p>
                    <div class="footer-socials">
                        <a href="#" class="social-link" aria-label="Instagram">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm.003 1.44c2.136 0 2.39.009 3.233.048.78.036 1.203.166 1.485.276.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.276 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.036.78-.166 1.203-.276 1.485-.145.373-.319.64-.599.92s-.546.453-.92.598c-.28.11-.704.24-1.485.276-.843.039-1.096.047-3.232.047s-2.39-.008-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.843-.038 1.097-.047 3.233-.047zm0 2.452a4.11 4.11 0 1 0 0 8.22 4.11 4.11 0 0 0 0-8.22zm0 6.775a2.664 2.664 0 1 1 0-5.328 2.664 2.664 0 0 1 0 5.328zm5.23-6.937a.96.96 0 1 1-1.92 0 .96.96 0 0 1 1.92 0z" />
                            </svg>
                        </a>
                        <a href="#" class="social-link" aria-label="Facebook">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951z" />
                            </svg>
                        </a>
                        <a href="#" class="social-link" aria-label="TikTok">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M9 0h1.98c.144.715.54 1.617 1.235 2.512C12.895 3.389 13.797 4 15 4v2c-1.753 0-3.07-.814-4-1.829V11a5 5 0 1 1-5-5v2a3 3 0 1 0 3 3z" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Col 2: Quick Links -->
                <div class="col-lg-2 col-md-6 col-6">
                    <h6 class="footer-heading">Explore</h6>
                    <ul class="footer-links">
                        <li><a href="/">Home</a></li>
                        <li><a href="/Product/ShopAll">Shop All</a></li>
                        <li><a href="/Rental/Index">Party Rentals</a></li>
                        <li><a href="/About">About Us</a></li>
                        <li><a href="/Contact">Contact</a></li>
                    </ul>
                </div>

                <!-- Col 3: Account -->
                <div class="col-lg-2 col-md-6 col-6">
                    <h6 class="footer-heading">My Account</h6>
                    <ul class="footer-links">
                        @if (string.IsNullOrEmpty(firstName))
                        {
                            <li><a asp-controller="Account" asp-action="Login">Login</a></li>
                            <li><a asp-controller="User" asp-action="CreateUser">Sign Up</a></li>
                        }
                        else
                        {
                            <li><a asp-controller="Order" asp-action="History">My Orders</a></li>
                            <li><a asp-controller="Cart" asp-action="Index">My Cart</a></li>
                            <li>
                                <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline p-0 m-0">
                                    <button type="submit" class="footer-logout-btn">Logout</button>
                                </form>
                            </li>
                        }
                    </ul>
                </div>

                <!-- Col 4: Contact -->
                <div class="col-lg-4 col-md-6">
                    <h6 class="footer-heading">Get In Touch</h6>
                    <ul class="footer-contact-list">
                        <li>
                            <span class="contact-icon">📍</span>
                            <span>Serving the greater Chicago area and surrounding suburbs</span>
                        </li>
                        <li>
                            <span class="contact-icon">📞</span>
                            <a href="tel:+15555555555">(555) 555-5555</a>
                        </li>
                        <li>
                            <span class="contact-icon">✉️</span>
                            <a href="mailto:hello@webringtheparty.com">hello@webringtheparty.com</a>
                        </li>
                        <li>
                            <span class="contact-icon">🕐</span>
                            <span>Mon–Sat: 9AM – 7PM</span>
                        </li>
                    </ul>
                </div>

            </div>
        </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
            <span>&copy; @DateTime.Now.Year WeBringTheParty. All rights reserved.</span>
            <div class="d-flex gap-3">
                <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                <a href="/Contact">Contact Us</a>
