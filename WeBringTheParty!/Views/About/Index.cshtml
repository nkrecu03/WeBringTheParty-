@{
    ViewData["Title"] = "About Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ═══════════════════════════════════════════
     HERO
═══════════════════════════════════════════ -->
<div class="contact-hero">
    <div class="contact-hero-overlay"></div>
    <div class="contact-hero-content">
        <h1 class="contact-hero-title">About Us</h1>
        <p class="contact-hero-sub">The story behind Chicago's favorite party crew.</p>
    </div>
</div>

<!-- ═══════════════════════════════════════════
     TWO CARD LAYOUT
═══════════════════════════════════════════ -->
<div class="container about-page-wrap">
    <div class="row g-0 about-card-row align-items-stretch">

        <!-- LEFT CARD — image -->
        <div class="col-lg-6">
            <div class="about-img-card">
                <img src="~/images/purple_disco.jpg"
                     alt="Party disco lights"
                     class="about-img" />
            </div>
        </div>

        <!-- RIGHT CARD — about us text -->
        <div class="col-lg-6">
            <div class="about-text-card">

                <span class="section-eyebrow">Our Story</span>
                <h2 class="about-heading">We Make Parties Better.</h2>

                <p>We Bring The Party was born out of frustration. Planning a celebration should be exciting, not a logistical nightmare of hunting down supplies, renting equipment from five different vendors, and figuring out who's going to haul a bounce house across town.</p>

                <p>We built a one-stop shop for everything you need to throw an unforgettable event — premium party supplies shipped to your door, and a rental fleet of equipment that we deliver, set up, and take back ourselves. You just show up and celebrate.</p>

                <p>Based in Chicago and serving the surrounding suburbs, we've helped over 1,000 events come to life — from backyard birthday parties to wedding receptions, corporate events, and everything in between.</p>

                

            </div>
        </div>

    </div>
</div>

<!-- ═══════════════════════════════════════════
     VALUES SECTION
═══════════════════════════════════════════ -->
<section class="about-values-section">
    <div class="container">

        <div class="text-center mb-5">
            <span class="section-eyebrow">What Drives Us</span>
            <h2 class="section-title">Our Values</h2>
        </div>

        <div class="row g-4">

            <div class="col-lg-3 col-md-6">
                <div class="about-value-card">
                    
                    <h5>Quality First</h5>
                    <p>Every product we ship and every piece of equipment we rent is inspected, cleaned, and party-ready. No exceptions.</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="about-value-card">
                    
                    <h5>Premium Service</h5>
                    <p>We don't just drop things off. We set up, we check in, and we make sure everything is exactly how you imagined it.</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="about-value-card">
                    
                    <h5>Reliability</h5>
                    <p>When you book with us, we show up. On time, fully prepared, and ready to make your event a success.</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="about-value-card">
                    
                    <h5>Community</h5>
                    <p>We're a Chicago business, through and through. Every party we serve strengthens the communities we call home.</p>
                </div>
            </div>

        </div>

    </div>
</section>

<!-- ═══════════════════════════════════════════
     CTA
═══════════════════════════════════════════ -->
<section class="cta-section">
    <div class="cta-overlay"></div>
    <div class="cta-content text-center">
        <h2>Ready to Plan Your Next Event?</h2>
        <p>Shop our products, browse our rentals, or reach out and we'll help you build the perfect party package.</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/Product/ShopAll" class="btn btn-cta-primary">Shop Products</a>
            <a href="/Rental/Index" class="btn btn-cta-outline">Browse Rentals</a>
            <a href="/Contact" class="btn btn-cta-outline">Contact Us</a>
        </div>
    </div>
</section>