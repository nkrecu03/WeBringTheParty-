@model IEnumerable<DataAccessLayer.Entities.ProductModel>
@{
    ViewData["Title"] = "Shop";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-hero-banner">
    <img src="~/images/orange_disco.jpg" alt="" class="page-hero-banner-img" />
    <div class="page-hero-banner-overlay"></div>
    <div class="page-hero-banner-text">
        <h1>Shop All Products</h1>
    </div>
</div>

<div class="container mt-5">
    

    <div class="shop-grid row g-4">
        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="product-card h-100 d-flex flex-column">

                    <!-- IMAGE CONTAINER -->
                    <div class="product-card-img-wrap">
                        <img src="@Url.Content("~/product_images/" + item.ImageUrl)"
                             alt="@item.Name"
                             class="product-card-img" />
                    </div>

                    <!-- CARD BODY -->
                    <div class="bs-card-body d-flex flex-column flex-grow-1">
                        <h5 class="bs-card-name">@item.Name</h5>
                        <p class="bs-card-price">$@item.Price</p>

                        <a asp-action="ProductDetails"
                           asp-route-id="@item.ProductID"
                           class="btn btn-purple mt-auto">
                            View Details
                        </a>
                    </div>

                </div>
            </div>
        }
    </div>
</div>