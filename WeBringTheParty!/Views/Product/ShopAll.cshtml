@model IEnumerable<DataAccessLayer.Entities.ProductModel>

@{
    ViewData["Title"] = "Shop";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <h2 class="text-center mb-4">Shop Our Products</h2>

    <div class="shop-grid row g-4">

        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6">

                <div class="product-card h-100 shadow-sm">

                    <!-- PRODUCT IMAGE -->
                    <img src="@Url.Content("~/product_images/" + item.ImageUrl)"
                         class="card-img-top"
                         alt="@item.Name"
                         style="height:250px; object-fit:cover;" />

                    <div class="d-flex flex-column">
                        
                        <!-- PRODUCT NAME -->
                        <h5 class="card-title">@item.Name</h5>

                        <!-- PRICE -->
                        <p class="fw-bold text-success fs-5">
                            $@item.Price
                        </p>

                        <!-- BUTTON -->
                        <a asp-action="Details"
                           asp-route-id="@item.ProductID"
                           class="create-account-btn btn btn-primary mt-auto">
                            View Details
                        </a>

                    </div>
                </div>

            </div>
        }

    </div>
</div>