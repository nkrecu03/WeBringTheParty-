@model DataAccessLayer.Entities.ProductModel
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="pd-page">
    <div class="container">

        <!-- Breadcrumb -->
        <nav class="pd-breadcrumb">
            <a href="/">Home</a>
            <span>›</span>
            <a href="/Product/ShopAll">Shop All</a>
            <span>›</span>
            <span>@Model.Name</span>
        </nav>

        <div class="row g-5 align-items-start">

            <!-- LEFT: Image -->
            <div class="col-lg-6">
                <div class="pd-img-card">
                    <img src="@Url.Content("~/product_images/" + Model.ImageUrl)"
                         alt="@Model.Name"
                         class="pd-img" />
                </div>
            </div>

            <!-- RIGHT: Info -->
            <div class="col-lg-6">
                <div class="pd-info">

                    <!-- Name -->
                    <h1 class="pd-name">@Model.Name</h1>

                    <!-- Price -->
                    <div class="pd-price-row">
                        <span class="pd-price">$@Model.Price</span>
                        @if (Model.QuantityAvailable > 0)
                        {
                            <span class="pd-stock-badge pd-in-stock">In Stock</span>
                        }
                        else
                        {
                            <span class="pd-stock-badge pd-out-of-stock">Out of Stock</span>
                        }
                    </div>

                    <hr class="pd-divider" />

                    <!-- Description -->
                    <p class="pd-description">@Model.Description</p>

                    <hr class="pd-divider" />

                    <!-- Stock count -->
                    <div class="pd-meta-row">
                        <span class="pd-meta-label">Available</span>
                        <span class="pd-meta-value">@Model.QuantityAvailable units</span>
                    </div>

                    <!-- Add to cart -->
                    @if (Model.QuantityAvailable > 0)
                    {
                        <form asp-controller="Product" asp-action="AddToCart" method="post" class="pd-form">
                            <input type="hidden" name="productId" value="@Model.ProductID" />

                            <div class="pd-qty-row">
                                <div class="pd-qty-wrap">
                                    <label class="pd-meta-label mb-1 d-block">Quantity</label>
                                    <div class="pd-qty-control">
                                        <button type="button" class="pd-qty-btn" onclick="changeQty(-1)">−</button>
                                        <input type="number"
                                               name="quantity"
                                               id="qtyInput"
                                               min="1"
                                               max="@Model.QuantityAvailable"
                                               value="1"
                                               class="pd-qty-input" />
                                        <button type="button" class="pd-qty-btn" onclick="changeQty(1)">+</button>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-purple pd-add-btn">
                                Add to Cart
                            </button>

                        </form>
                    }
                    else
                    {
                        <button class="btn pd-add-btn pd-disabled-btn" disabled>
                            Out of Stock
                        </button>
                    }

                    <!-- Back link -->
                    <a href="/Product/ShopAll" class="pd-back-link">← Back to Shop</a>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeQty(delta) {
            const input = document.getElementById('qtyInput');
            const max   = parseInt(input.max);
            const min   = parseInt(input.min);
            let val     = parseInt(input.value) + delta;
            if (val < min) val = min;
            if (val > max) val = max;
            input.value = val;
        }
    </script>
}