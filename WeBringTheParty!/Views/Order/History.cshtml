@model IEnumerable<DataAccessLayer.Entities.OrderModel>

<div class="container my-5">
    <h2 class="fw-bold mb-4">Your Order History</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted">You haven't placed any orders yet.</p>
            <a href="@Url.Action("ShopAll", "Product")" class="btn btn-primary">Start Shopping</a>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted">Order Placed:</span>
                        <span class="fw-bold">@order.Date.ToString("MMMM dd, yyyy")</span>
                    </div>
                    <span class="badge bg-secondary">Order #@order.OrderId</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-9">
                            @foreach (var item in order.OrderItems)
                            {
                                <div class="d-flex justify-content-between border-bottom py-2">
                                    <span>@item.Product.Name (x @item.Quantity)</span>
                                    <span class="text-muted">$@(item.Product.Price* item.Quantity)</span>
                                </div>
                            }
                        </div>
                        <div class="col-md-3 text-end d-flex align-items-center justify-content-end">
                            <div>
                                <div class="small text-muted">Order Total</div>
                                <div class="h5 fw-bold">$@order.OrderItems.Sum(oi => oi.Product.Price * oi.Quantity)</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>