@model IEnumerable<DataAccessLayer.Entities.CartItemModel>

<div class="container my-5">
    <h2 class="fw-bold mb-4">Confirm Your Order</h2>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Review Items</h5>
                </div>
                <div class="card-body">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th class="text-end">Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="~/product_images/@item.Product.ImageUrl" style="width: 40px;" class="rounded me-2" />
                                            <span>@item.Product.Name</span>
                                        </div>
                                    </td>
                                    <td>@item.Quantity</td>
                                    <td class="text-end">$@(item.Product.Price* item.Quantity)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-success">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Order Summary</h5>
                    <hr />
                    <div class="d-flex justify-content-between mb-3">
                        <span>Total Due:</span>
                        <span class="h4 fw-bold text-success">$@Model.Sum(x => x.Product.Price * x.Quantity)</span>
                    </div>

                    <form asp-action="PlaceOrder" method="post">
                        <button type="submit" class="btn btn-success btn-lg w-100">Complete Purchase</button>
                    </form>
                    <a asp-controller="Cart" asp-action="Index" class="btn btn-link w-100 mt-2 text-muted">Back to Cart</a>
                </div>
            </div>
            <div class="mt-3 text-center small text-muted">
                <i class="bi bi-shield-check"></i> No real payment integration required for Sprint 3.
            </div>
        </div>
    </div>
</div>
