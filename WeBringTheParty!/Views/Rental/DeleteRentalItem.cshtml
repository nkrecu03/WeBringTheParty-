@model DataAccessLayer.Entities.RentalItemModel

@{
    ViewData["Title"] = "Delete Rental Item";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Delete Rental Item</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Model.Description</dd>

        <dt class="col-sm-3">Price / Day</dt>
        <dd class="col-sm-9">$@Model.RentalPricePerDay</dd>

        <dt class="col-sm-3">Delivery Fee</dt>
        <dd class="col-sm-9">$@Model.DeliveryFee</dd>

        <dt class="col-sm-3">Key Features</dt>
        <dd class="col-sm-9">@Model.KeyFeatures</dd>

        <dt class="col-sm-3">Image</dt>
        <dd class="col-sm-9">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Url.Content("~/product_images/" + Model.ImageUrl)"
                     style="max-height:80px; border-radius:6px;" />
            }
        </dd>

        <dt class="col-sm-3">Active</dt>
        <dd class="col-sm-9">@Model.IsActive</dd>
    </dl>

    <form asp-action="DeleteRentalItem">
        <input type="hidden" asp-for="RentalItemID" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="AdminIndex" class="btn btn-secondary ms-2">Back to List</a>
    </form>
</div>