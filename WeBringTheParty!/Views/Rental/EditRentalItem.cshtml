@model DataAccessLayer.Entities.RentalItemModel

@{
    ViewData["Title"] = "Edit Rental Item";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Edit Rental Item</h1>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="EditRentalItem" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="RentalItemID" />

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="KeyFeatures" class="control-label"></label>
                <textarea asp-for="KeyFeatures" class="form-control" rows="4"></textarea>
                <small class="text-muted">Separate each feature with a pipe character <strong>|</strong></small>
                <span asp-validation-for="KeyFeatures" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="RentalPricePerDay" class="control-label"></label>
                <input asp-for="RentalPricePerDay" class="form-control" />
                <span asp-validation-for="RentalPricePerDay" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DeliveryFee" class="control-label"></label>
                <input asp-for="DeliveryFee" class="form-control" />
                <span asp-validation-for="DeliveryFee" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="ImageFile">Replace Image <small class="text-muted">(leave blank to keep current)</small></label>
                <input type="file" class="form-control" id="ImageFile" name="ImageFile" accept="image/*" />
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mt-2">
                        <small class="text-muted">Current: @Model.ImageUrl</small><br />
                        <img src="@Url.Content("~/product_images/" + Model.ImageUrl)"
                             style="max-height:100px; margin-top:6px; border-radius:6px;" />
                    </div>
                    <input type="hidden" asp-for="ImageUrl" />
                }
            </div>

            <div class="form-group form-check mb-3">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsActive" /> Active
                </label>
            </div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="AdminIndex" class="btn btn-secondary ms-2">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}