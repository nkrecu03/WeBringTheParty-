@model DataAccessLayer.Entities.LoginModel

<div class="container">
    <h2>Login</h2>

    <form asp-action="Login" method="post">
        <div>
            <label asp-for="Email"></label>
            <input asp-for="Email" style="margin-left: 100px;" />
        </div>
        <div>
            <label asp-for="Password"></label>
            <input asp-for="Password" type="password" style="margin-left: 72px;" />
        </div>
        <button type="submit">Login</button>
    </form>

    @if (ViewBag.Error != null)
    {
        <p style="color:red">@ViewBag.Error</p>
    }

</div>